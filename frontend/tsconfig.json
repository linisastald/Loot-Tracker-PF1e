{
  "compilerOptions": {
    // TS 6 deprecates target=ES5, moduleResolution=node10, and baseUrl (they
    // still work until TS 7). Silencing for now to keep this a behavior-neutral
    // TS 6 bump; modernizing these (target->ES2020+, moduleResolution->bundler,
    // drop baseUrl) is a separate task to do before TS 7.
    "ignoreDeprecations": "6.0",
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@/components/*": ["components/*"],
      "@/utils/*": ["utils/*"],
      "@/services/*": ["services/*"],
      "@/types/*": ["types/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "src/**/__tests__/**",
    "src/**/*.test.*"
  ]
}